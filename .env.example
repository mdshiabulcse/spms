# Copy this file to `.env` and edit values for your machine.
# PowerShell: Copy-Item .env.example .env

# --- Use PostgreSQL (set USE_SQLITE=0) ---
USE_SQLITE=0

DB_NAME=clinic_db
DB_USER=postgres
DB_PASSWORD=8085
DB_HOST=localhost
DB_PORT=5432

# --- Use SQLite instead (local file: data/db.sqlite3) ---
# USE_SQLITE=1

# Optional
# SECRET_KEY=change-me-in-production
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
