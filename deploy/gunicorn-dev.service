[Unit]
Description=Clinic App (Gunicorn - dev/LAN)
After=network.target postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/clinic
EnvironmentFile=/var/www/clinic/.env
ExecStart=/var/www/clinic/.venv/bin/gunicorn --workers 2 --bind unix:/var/www/clinic/run/gunicorn.sock config.wsgi:application
Restart=on-failure

[Install]
WantedBy=multi-user.target
