# Developer / LAN deploy on Ubuntu — copy to .env on server
# cp .env.dev.example .env

USE_SQLITE=0

DB_NAME=clinic_db
DB_USER=clinic_user
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=5432

SECRET_KEY=change-me-dev-only
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.10,clinic.local
CSRF_TRUSTED_ORIGINS=http://192.168.1.10,http://clinic.local,http://localhost

# Replace 192.168.1.10 with your Ubuntu server LAN IP
